{
  "sourceLanguage": "en",
  "strings": {
    "%lld hours": {
      "comment": "Label for duration in hours",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小时"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小時"
          }
        }
      }
    },
    "%lld minutes": {
      "comment": "Label for duration in minutes",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分鐘"
          }
        }
      }
    },
    "Anti-sleep mode enabled via Wakey": {
      "comment": "Reason shown in system power assertions when anti-sleep is active",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用户通过 Wakey 开启了防休眠模式"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "用戶通過 Wakey 開啟了防休眠模式"
          }
        }
      }
    },
    "Caffeinate": {
      "comment": "Name of the anti-sleep plugin",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "防休眠"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "防休眠"
          }
        }
      }
    },
    "Indefinite": {
      "comment": "Label for infinite duration",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "永久"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "永久"
          }
        }
      }
    },
    "Keep system awake, allow display sleep": {
      "comment": "Option to prevent system sleep but allow the monitor to turn off",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠，允许关闭屏幕"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠，允許關閉螢幕"
          }
        }
      }
    },
    "Keep system awake, prevent display sleep": {
      "comment": "Option to prevent both system and monitor from sleeping",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠，禁止关闭屏幕"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止休眠，禁止關閉螢幕"
          }
        }
      }
    },
    "Prevent system sleep, supporting scheduled and manual control": {
      "comment": "Description of what the Caffeinate plugin does",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止系统休眠，支持定时和手动控制"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "阻止系統休眠，支援定時和手動控制"
          }
        }
      }
    }
  },
  "version": "1.1"
}