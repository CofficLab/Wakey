{
  "sourceLanguage": "en",
  "strings": {
    "%lld hr": {
      "comment": "Label for duration in hours",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小时"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小時"
          }
        }
      }
    },
    "%lld min": {
      "comment": "Label for duration in minutes",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分鐘"
          }
        }
      }
    },
    "Add Custom (minutes):": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加自定义（分钟）："
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "添加自訂（分鐘）："
          }
        }
      }
    },
    "Break reminder is off": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "护眼提醒已关闭"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "護眼提醒已關閉"
          }
        }
      }
    },
    "Delete": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除"
          }
        }
      }
    },
    "Eye Care": {
      "comment": "Name of the eye care reminder plugin",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "护眼"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "護眼"
          }
        }
      }
    },
    "Interval": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒间隔"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒間隔"
          }
        }
      }
    },
    "Look away from the screen for 20 seconds to rest your eyes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远离屏幕20秒，让眼睛休息一下。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "遠離螢幕20秒，讓眼睛休息一下。"
          }
        }
      }
    },
    "Manage your custom reminder intervals. Click the delete button to remove custom intervals.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "管理您的自定义提醒时长。点击删除按钮可删除自定义时长。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "管理您的自訂提醒時長。點擊刪除按鈕可刪除自定義時長。"
          }
        }
      }
    },
    "Next break: %lld mins": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：%lld 分鐘"
          }
        }
      }
    },
    "Next break: 1 min": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：1分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：1分鐘"
          }
        }
      }
    },
    "Next break: less than 1 min": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：不到1分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：不到1分鐘"
          }
        }
      }
    },
    "Notifications Disabled": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已禁用"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已禁用"
          }
        }
      }
    },
    "Open Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开设置"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟設定"
          }
        }
      }
    },
    "Please enable notifications in System Settings to receive break reminders.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在系统设置中启用通知，以便接收休息提醒。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "請在系統設定中啟用通知，以便接收休息提醒。"
          }
        }
      }
    },
    "Remind you to rest your eyes every 20 minutes": {
      "comment": "Description of what the Eye Care Reminder plugin does",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每20分钟提醒你休息眼睛"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每20分鐘提醒你休息眼睛"
          }
        }
      }
    },
    "Reminder Intervals": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒间隔"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒間隔"
          }
        }
      }
    },
    "Reset to Default Intervals": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恢复默认时长"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "恢復預設時長"
          }
        }
      }
    },
    "Status": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "状态"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "狀態"
          }
        }
      }
    },
    "Today: %lld breaks": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今日：%lld 次休息"
          }
