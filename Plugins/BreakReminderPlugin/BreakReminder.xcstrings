{
  "sourceLanguage": "en",
  "strings": {
    "Break Reminder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "休息提醒"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "休息提醒"
          }
        }
      }
    },
    "Remind you to take healthy breaks during long work sessions": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在长时间工作中提醒你健康休息"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "在長時間工作中提醒你健康休息"
          }
        }
      }
    },
    "Eye Care": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "护眼"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "護眼"
          }
        }
      }
    },
    "Stretch": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "活动"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "活動"
          }
        }
      }
    },
    "Hydration": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "补水"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "補水"
          }
        }
      }
    },
    "Rest your eyes every 20 minutes": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每20分钟让眼睛休息"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每20分鐘讓眼睛休息"
          }
        }
      }
    },
    "Move your body every hour": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每小时活动身体"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每小時活動身體"
          }
        }
      }
    },
    "Stay hydrated every 2 hours": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每2小时补充水分"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每2小時補充水分"
          }
        }
      }
    },
    "Look away from the screen for 20 seconds to rest your eyes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远离屏幕20秒，让眼睛休息一下。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "遠離螢幕20秒，讓眼睛休息一下。"
          }
        }
      }
    },
    "Time to stand up and stretch your body.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "站起来活动一下身体吧。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "站起來活動一下身體吧。"
          }
        }
      }
    },
    "Don't forget to drink some water!": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "别忘了喝水！"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "別忘記喝水！"
          }
        }
      }
    },
    "Time for a Break!": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "该休息了！"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
