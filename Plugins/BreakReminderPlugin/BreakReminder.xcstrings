    "Look away from the screen for 20 seconds to rest your eyes.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "远离屏幕20秒，让眼睛休息一下。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "遠離螢幕20秒，讓眼睛休息一下。"
          }
        }
      }
    },
    "Move your body every hour": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每小时活动身体"
