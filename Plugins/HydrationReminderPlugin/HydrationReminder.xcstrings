{
  "sourceLanguage": "en",
  "strings": {
    "%lld hr": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小时"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小時"
          }
        }
      }
    },
    "%lld min": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分鐘"
          }
        }
      }
    },
    "Break reminder is off": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "补水提醒已关闭"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "補水提醒已關閉"
          }
        }
      }
    },
