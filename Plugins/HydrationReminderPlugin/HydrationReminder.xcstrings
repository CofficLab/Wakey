      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒间隔"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒間隔"
          }
        }
      }
    },
