      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自定义（分钟）："
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "自訂（分鐘）："
          }
        }
      }
    },
    "Customize how often you want to be reminded to drink water.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自定义喝水提醒的频率。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "自訂喝水提醒的頻率。"
          }
        }
      }
    },
    "Don't forget to drink some water!": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "别忘了喝点水！"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "別忘記喝點水！"
          }
        }
      }
    },
