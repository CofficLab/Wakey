        }
      }
    },
    "Notifications Disabled": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已禁用"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已禁用"
          }
        }
      }
    },
    "Open Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开设置"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟設定"
          }
        }
      }
    },
    "Please enable notifications in System Settings to receive break reminders.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在系统设置中启用通知，以便接收休息提醒。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "請在系統設定中啟用通知，以便接收休息提醒。"
          }
        }
      }
    },
    "Remind you to stay hydrated every 2 hours": {
      "comment": "Description of what the Hydration Reminder plugin does",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每2小时提醒你补水"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每2小時提醒你補水"
          }
        }
      }
    },
    "Reminder Intervals": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒间隔"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒間隔"
          }
        }
      }
    },
    "Select an interval to activate it. Right-click custom intervals to delete them.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择一个间隔以激活它。右键单击自定义间隔以删除它们。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇一個間隔以激活它。右鍵單擊自定義間隔以刪除它們。"
          }
        }
      }
    },
    "Status": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "状态"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "狀態"
          }
        }
      }
    },
    "Today: %lld breaks": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今日：%lld 次休息"
          }
