            "value": "%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分鐘"
          }
        }
      }
    },
    "Add Custom (minutes):": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加自定义(分钟):"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "添加自訂(分鐘):"
          }
        }
      }
    },
    "Break reminder is off": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "补水提醒已关闭"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "補水提醒已關閉"
          }
        }
      }
    },
    "Delete": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除"
          }
        }
      }
    },
    "Don't forget to drink some water!": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "别忘了喝点水！"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "別忘記喝點水！"
          }
        }
      }
    },
    "Enable Hydration Reminder": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用补水提醒"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "啟用補水提醒"
          }
        }
      }
    },
    "Hydration": {
      "comment": "Name of the hydration reminder plugin",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "补水"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "補水"
          }
        }
      }
    },
