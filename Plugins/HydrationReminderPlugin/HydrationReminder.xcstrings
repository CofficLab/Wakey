    },
    "Next break: 1 min": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：1分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：1分鐘"
          }
        }
