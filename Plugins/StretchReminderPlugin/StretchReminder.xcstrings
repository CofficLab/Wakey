      "comment": "Button to start stretch reminder",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开始"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開始"
          }
        }
      }
    },
    "Stop_Button": {
      "comment": "Button to stop stretch reminder",
      "localizations": {
