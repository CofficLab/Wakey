{
  "sourceLanguage": "en",
  "strings": {
    "%lld hr": {
      "comment": "Label for duration in hours",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小时"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 小時"
          }
        }
      }
    },
    "%lld min": {
      "comment": "Label for duration in minutes",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分鐘"
          }
        }
      }
    },
    "Add Custom (minutes):": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加自定义(分钟):"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "添加自訂(分鐘):"
          }
        }
      }
    },
    "Break reminder is off": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "活动提醒已关闭"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "活動提醒已關閉"
          }
        }
      }
    },
    "Delete": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除"
          }
        }
      }
    },
    "Interval": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒间隔"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒間隔"
          }
        }
      }
    },
    "Manage your custom reminder intervals. Click the delete button to remove custom intervals.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "管理您的自定义提醒时长。点击删除按钮可删除自定义时长。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "管理您的自訂提醒時長。點擊刪除按鈕可刪除自定義時長。"
          }
        }
      }
    },
    "Next break: %lld mins": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：%lld 分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：%lld 分鐘"
          }
        }
      }
    },
    "Next break: 1 min": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：1分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：1分鐘"
          }
        }
      }
    },
    "Next break: less than 1 min": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：不到1分钟"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "下次休息：不到1分鐘"
          }
        }
      }
    },
    "Notifications Disabled": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已禁用"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "通知已禁用"
          }
        }
      }
    },
    "Open Settings": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "打开设置"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟設定"
          }
        }
      }
    },
    "Please enable notifications in System Settings to receive break reminders.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在系统设置中启用通知，以便接收休息提醒。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "請在系統設定中啟用通知，以便接收休息提醒。"
          }
        }
      }
    },
    "Remind you to move your body every hour": {
      "comment": "Description of what the Stretch Reminder plugin does",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每小时提醒你活动身体"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "每小時提醒你活動身體"
          }
        }
      }
    },
    "Reminder Intervals": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒间隔"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "提醒間隔"
          }
        }
      }
    },
    "Reset to Default Intervals": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恢复默认时长"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "恢復預設時長"
          }
        }
      }
    },
    "Status": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "状态"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "狀態"
          }
        }
      }
    },
    "Stretch": {
      "comment": "Name of the stretch reminder plugin",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "活动"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "活動"
          }
        }
      }
    },
    "Time to stand up and stretch your body.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "站起来活动一下身体吧。"
          }
        },
        "zh-HK": {
          "stringUnit": {
            "state": "translated",
            "value": "站起來活動一下身體吧。"
          }
        }
      }
    },
    "Today: %lld breaks": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "今日：%lld 次休息"
          }
        },
